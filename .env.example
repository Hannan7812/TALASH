# -------------------------
# LLM (Groq)
# -------------------------
GROQ_API_KEY=
# Options include:
# llama-3.3-70b-versatile
# mixtral-8x7b-32768
# deepseek-r1-distill-llama-70b
GROQ_MODEL=llama-3.3-70b-versatile
LLM_MAX_JSON_RETRIES=3

# -------------------------
# Database (Supabase Postgres)
# -------------------------
# Use the Supabase "Transaction pooler" or direct Postgres URI.
# You can set either SUPABASE_DB_URL or DATABASE_URL.
SUPABASE_DB_URL=
# DATABASE_URL takes precedence if set. It can also be postgres:// or postgresql://.
# DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# For managed Supabase, keep this false and apply schema manually via SQL editor.
AUTO_INIT_DB=false
